# Google Gemini API Key
GOOGLE_GEMINI_API_KEY="your-google-gemini-api-key-here"

# Groq API Key
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3-turbo"

# Optional YouTube request tuning for audio fallback on serverless hosts.
# Set YOUTUBE_COOKIE to a valid YouTube cookie string only if downloads are blocked by bot checks.
YOUTUBE_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
YOUTUBE_COOKIE=""

# OpenRouter API Key
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENROUTER_MODEL="openrouter/auto"

# Optional NVIDIA API Key (for DeepSeek v3.2)
NVIDIA_API_KEY="your-nvidia-api-key-here"

# Server Port (optional, defaults to 3000)
PORT=3000

# Firebase Admin service account JSON (required for secure plan enforcement)
# Example: FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account"}'

# Razorpay Pro checkout
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
RAZORPAY_CURRENCY="INR"
RAZORPAY_PRO_AMOUNT=29900
RAZORPAY_PRO_DURATION_DAYS=30
